{
  "name": "playwright-daraz-tests",
  "version": "1.0.0",
  "description": "E2E automation suite for Daraz.pk — Pakistan's leading e-commerce platform",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "report": "playwright show-report",
    "lint": "tsc --noEmit"
  },
  "keywords": ["playwright", "daraz", "e-commerce", "pakistan", "qa"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
